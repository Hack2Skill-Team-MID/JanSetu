# ===========================================
# JanSetu Server — Environment Variables
# Copy this file to ../../.env and fill in values
# OR set these in the root .env.example
# ===========================================

# === Database (PostgreSQL) — REQUIRED ===
# Create the DB first: createdb jansetu
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/jansetu

# === Authentication — REQUIRED ===
JWT_SECRET=your-super-secret-jwt-key-here-min-32-chars
JWT_EXPIRES_IN=7d

# === Server ===
PORT=5000
NODE_ENV=development

# === Gemini AI (Optional) ===
# Without this key, the AI chatbot uses a rich offline fallback mode
# Get a FREE key at: https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key-here

# === Razorpay Payment (Optional) ===
# Without these, the platform auto-switches to Demo Mode (no real payment needed)
# Get test keys at: https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# === Notifications (Optional — not required for local dev) ===
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
SENDGRID_API_KEY=your-sendgrid-key

# === AI Service (Optional microservice) ===
AI_SERVICE_URL=http://localhost:8000
